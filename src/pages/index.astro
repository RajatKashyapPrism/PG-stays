---
import Hero from '../components/Hero.astro';
import Recco01 from '../components/Recco01.astro';
import ModernStandard from '../components/ModernStandard.astro';
import Recco02 from '../components/Recco02.astro';
import OurSimpleProcess from '../components/OurSimpleProcess.astro';
import Amenities from '../components/Amenities.astro';
import '../styles/global.css';
---

<html lang="en" data-brand="oyo" data-density="comfortable">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
		<title>Premium PG Living - Zero Hassle</title>
	<style>
		body {
			display: flex;
			flex-direction: column;
			align-items: center;
			margin: 0 auto;
		}
	</style>
	</head>
	<body>
		<Hero />
		<Recco01 />
		<ModernStandard />
		<Recco02 />
		<OurSimpleProcess />
		<Amenities />
	</body>
</html>
