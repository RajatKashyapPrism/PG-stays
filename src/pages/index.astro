---
import Navbar from '../sections/Navbar.astro';
import Hero from '../sections/Hero.astro';
import Recco01 from '../sections/Recco01.astro';
import ModernStandard from '../sections/ModernStandard.astro';
import Recco02 from '../sections/Recco02.astro';
import AvailableInTopCities from '../sections/AvailableInTopCities.astro';
import OurSimpleProcess from '../sections/OurSimpleProcess.astro';
import Amenities from '../sections/Amenities.astro';
import Testimonials from '../sections/Testimonials.astro';
import LeadGenForm from '../sections/LeadGenForm.astro';
import FAQ from '../sections/FAQ.astro';
import '../styles/global.css';
---

<html lang="en" data-brand="oyo" data-density="comfortable">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
		<title>Premium PG Living - Zero Hassle</title>
	<style>
		html {
			scroll-behavior: smooth;
		}
		body {
			display: flex;
			flex-direction: column;
			align-items: center;
			margin: 0 auto;
		}
	</style>
	</head>
	<body>
		<Navbar />
		<Hero />
		<Recco01 />
		<ModernStandard />
		<Recco02 />
		<AvailableInTopCities />
		<OurSimpleProcess />
		<Amenities />
		<Testimonials />
		<LeadGenForm />
		<FAQ />
	</body>
</html>
