---
const cities = [
  {
    title: 'Bengaluru',
    image: '/images/city-bengaluru.webp',
    imageClass: 'city-tile__image--bengaluru',
  },
  {
    title: 'Hyderabad',
    image: '/images/city-hyderabad.webp',
    imageClass: 'city-tile__image--hyderabad',
  },
  {
    title: 'Gurugram',
    image: '/images/city-gurugram.webp',
    imageClass: 'city-tile__image--gurgaon',
  },
  {
    title: 'Pune',
    image: '/images/city-pune.webp',
    imageClass: 'city-tile__image--pune',
  },
  {
    title: 'Mumbai',
    image: '/images/city-mumbai.webp',
    imageClass: 'city-tile__image--mumbai',
  },
  {
    title: 'Noida',
    image: '/images/city-noida.webp',
    imageClass: 'city-tile__image--noida',
  },
];
---

<section class="top-cities">
  <div class="top-cities__header-wrap">
    <div class="top-cities__header">
      <h2 class="top-cities__title">Available in Top Cities</h2>
      <p class="top-cities__subtitle">Find us in the heart of India's biggest hubs.</p>
    </div>
  </div>

  <div class="top-cities__content-wrap">
    <div class="top-cities__row">
      {cities.map((city) => (
        <article class="city-tile" role="button" tabindex="0" data-city={city.title} aria-label={`Select ${city.title}`}>
          <div class="city-tile__media">
            <img class={`city-tile__image ${city.imageClass}`} src={city.image} alt={city.title} loading="lazy" />
          </div>
          <div class="city-tile__overlay">
            <h3 class="city-tile__title">{city.title}</h3>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .top-cities {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    align-items: center;
    justify-content: center;
    width: 100%;
    overflow: clip;
    background: var(--colour-background-subtle-neutral-1, #ffffff);
    border-radius: 24px;
    padding-top: var(--space-scale-md-1, 24px);
    padding-right: var(--space-fixed-md-2, 32px);
    padding-bottom: var(--space-scale-md-3, 40px);
    padding-left: var(--space-fixed-md-2, 32px);
  }

  .top-cities__header-wrap,
  .top-cities__content-wrap {
    width: 100%;
    max-width: 1200px;
  }

  .top-cities__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-fixed-sm-3, 8px);
    width: 100%;
    padding-top: var(--space-fixed-sm-5, 16px);
    padding-bottom: var(--space-fixed-sm-3, 8px);
    text-align: center;
  }

  .top-cities__title {
    width: 100%;
    margin: 0;
    color: var(--colour-text-intense-neutral, #282828);
    font-family: var(--font-family-heading, var(--font-family-body));
    font-size: var(--font-size-h4, 32px);
    font-weight: var(--font-weight-heading, 700);
    line-height: var(--font-line-height-h4, 40px);
    letter-spacing: var(--font-letter-spacing-h4, -0.6px);
    font-feature-settings: 'ss01' 1, 'cv06' 1, 'cv05' 1, 'cv08' 1, 'cv10' 1;
  }

  .top-cities__subtitle {
    width: 100%;
    margin: 0;
    color: var(--colour-text-moderate-neutral, #6c6c6c);
    font-family: var(--font-family-body);
    font-size: var(--font-size-subtitle-1, 16px);
    font-weight: var(--font-weight-regular, 400);
    line-height: var(--font-line-height-subtitle-1, 24px);
    letter-spacing: var(--font-letter-spacing-subtitle-1-regular, 0px);
    font-feature-settings: 'ss01' 1, 'cv01' 1, 'cv02' 1, 'cv03' 1, 'cv04' 1, 'cv05' 1, 'cv06' 1, 'cv08' 1;
  }

  .top-cities__row {
    display: flex;
    gap: var(--space-fixed-md-1, 24px);
    align-items: stretch;
    width: 100%;
  }

  .city-tile {
    position: relative;
    flex: 1 0 0;
    cursor: pointer;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: calc((100% - (5 * var(--space-fixed-md-1, 24px))) / 6);
    min-width: 0;
    overflow: clip;
    border-radius: var(--size-border-radius-xl, 16px);
    background: #d9d9d9;
  }

  .city-tile__media {
    position: absolute;
    inset: 0;
    overflow: clip;
    border-radius: var(--size-border-radius-xl, 16px);
  }

  .city-tile__image {
    position: absolute;
    display: block;
    max-width: none;
  }

  .city-tile__image--bengaluru {
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .city-tile__image--hyderabad {
    top: -7.45%;
    left: -65.57%;
    width: 191.03%;
    height: 107.45%;
  }

  .city-tile__image--gurgaon {
    top: -0.14%;
    left: -55.23%;
    width: 191.36%;
    height: 127.59%;
  }

  .city-tile__image--pune {
    top: -37.53%;
    left: -65.38%;
    width: 239.25%;
    height: 159.52%;
  }

  .city-tile__image--mumbai {
    top: -33.94%;
    left: -78.42%;
    width: 215.72%;
    height: 143.89%;
  }

  .city-tile__image--noida {
    top: -12.57%;
    left: -56.45%;
    width: 170.04%;
    height: 112.63%;
  }

  .city-tile__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: var(--space-fixed-sm-5, 16px);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 44%, rgba(0, 0, 0, 0.72) 100%);
  }

  .city-tile__title {
    width: 100%;
    margin: 0;
    color: var(--colour-agnostic-white, #ffffff);
    font-family: var(--font-family-heading, var(--font-family-body));
    font-size: var(--font-size-h6, 20px);
    font-weight: var(--font-weight-heading, 700);
    line-height: var(--font-line-height-h6, 26px);
    letter-spacing: var(--font-letter-spacing-h6, -0.35px);
    font-feature-settings: 'cv01' 1, 'cv02' 1, 'cv03' 1, 'cv04' 1, 'cv05' 1, 'cv06' 1, 'cv08' 1, 'cv10' 1, 'ss01' 1, 'ss03' 1, 'cv09' 1;
  }

  @media (max-width: 640px) {
    .top-cities {
      gap: var(--space-fixed-sm-5, 16px);
      border-radius: var(--size-border-radius-xl, 16px);
      padding-top: var(--space-fixed-sm-3, 8px);
      padding-bottom: var(--space-fixed-md-1, 24px);
      padding-right: 0;
      padding-left: 0;
      overflow: visible;
      align-items: stretch;
    }

    .top-cities__header-wrap {
      padding-right: var(--space-fixed-sm-5, 16px);
      padding-left: var(--space-fixed-sm-5, 16px);
    }

    .top-cities__header {
      align-items: flex-start;
      text-align: left;
    }

    .top-cities__title {
      font-size: var(--font-size-h5, 25px);
      line-height: var(--font-line-height-h5, 30px);
      letter-spacing: var(--font-letter-spacing-h5, -0.5px);
    }

    .top-cities__content-wrap {
      max-width: 100%;
      overflow: visible;
    }

    .top-cities__row {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: visible;
      scroll-snap-type: x mandatory;
      scroll-padding-left: var(--space-fixed-sm-5, 16px);
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-right: var(--space-fixed-sm-5, 16px);
      padding-bottom: var(--fixed-50, 4px);
      padding-left: var(--space-fixed-sm-5, 16px);
      gap: var(--space-fixed-sm-5, 16px);
    }

    .top-cities__row::-webkit-scrollbar {
      display: none;
    }

    .city-tile {
      scroll-snap-align: start;
      flex: 0 0 var(--scale-1400, 128px);
      min-width: var(--scale-1400, 128px);
      max-width: none;
    }

    .city-tile__title {
      font-size: var(--font-size-subtitle-1, 16px);
      line-height: var(--font-line-height-subtitle-1, 24px);
      letter-spacing: var(--font-letter-spacing-subtitle-1-high, -0.3px);
    }
  }
</style>

<script>
  function selectCity(cityName: string) {
    const form = document.getElementById('hero-contact-form');
    const input = form?.querySelector<HTMLInputElement>('input[name="city"]');
    if (input) {
      const nativeSetter = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, 'value')?.set;
      if (nativeSetter) {
        nativeSetter.call(input, cityName);
      } else {
        input.value = cityName;
      }
      input.dispatchEvent(new Event('input', { bubbles: true }));
      input.dispatchEvent(new Event('change', { bubbles: true }));
    }
    form?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  document.querySelectorAll<HTMLElement>('.city-tile[data-city]').forEach((tile) => {
    tile.addEventListener('click', () => selectCity(tile.dataset.city!));
    tile.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        selectCity(tile.dataset.city!);
      }
    });
  });
</script>
