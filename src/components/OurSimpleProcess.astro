---
// Images from Figma design
const imgFindARoom = "https://www.figma.com/api/mcp/asset/09689659-82a2-47db-af54-a35dc493ac27";
const imgBookFreeVisit = "https://www.figma.com/api/mcp/asset/f2e942ff-d6b9-4b89-bddd-4f054f9c4796";
const imgMoveInNoBrokerage = "https://www.figma.com/api/mcp/asset/d97f9e73-4e30-489a-be5d-0e636d8f231c";

const steps = [
  {
    image: imgFindARoom,
    title: "Find a room",
    description: "Browse PG rooms in your preferred city"
  },
  {
    image: imgBookFreeVisit,
    title: "Book a free visit",
    description: "Schedule a visit to explore the property"
  },
  {
    image: imgMoveInNoBrokerage,
    title: "Move in - No brokerage",
    description: "Confirm booking and move in with zero brokerage"
  }
];
---

<section class="our-simple-process">
  <!-- Header -->
  <div class="process-header-wrapper">
    <div class="process-header">
      <h2 class="process-title">Our simple process</h2>
      <p class="process-subtitle">Find and move into your perfect PG in just three easy steps</p>
    </div>
  </div>

  <!-- Steps -->
  <div class="process-content-wrapper">
    <div class="steps-grid">
      {steps.map((step) => (
        <div class="step-card">
          <div class="step-image">
            <img src={step.image} alt={step.title} />
          </div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .our-simple-process {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    align-items: center;
    background-color: var(--colour-background-subtle-neutral-1, #ffffff);
    padding-bottom: var(--space-scale-md-3, 40px);
    padding-top: var(--space-fixed-md-1, 24px);
    padding-left: var(--space-fixed-md-4, 48px);
    padding-right: var(--space-fixed-md-4, 48px);
    border-radius: var(--size-border-radius-xl, 16px);
    width: 100%;
  }

  /* ── Header ── */
  .process-header-wrapper {
    max-width: 1200px;
    width: 100%;
  }

  .process-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-3, 8px);
    align-items: center;
    justify-content: center;
    padding-bottom: var(--space-fixed-sm-3, 8px);
    padding-top: var(--space-fixed-sm-5, 16px);
    text-align: center;
    width: 100%;
  }

  .process-title {
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-heading, 700);
    font-size: var(--font-size-h4, 32px);
    line-height: var(--font-line-height-h4, 40px);
    letter-spacing: var(--font-letter-spacing-h4, -0.6px);
    color: var(--colour-text-intense-neutral, #282828);
    font-feature-settings: 'ss01' 1, 'cv06' 1, 'cv05' 1, 'cv08' 1, 'cv10' 1;
    margin: 0;
  }

  .process-subtitle {
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular, 400);
    font-size: var(--font-size-subtitle-1, 16px);
    line-height: var(--font-line-height-subtitle-1, 24px);
    letter-spacing: var(--font-letter-spacing-subtitle-1-regular, 0px);
    color: var(--colour-text-moderate-neutral, #6c6c6c);
    font-feature-settings: 'ss01' 1, 'cv01' 1, 'cv02' 1, 'cv03' 1, 'cv04' 1, 'cv05' 1, 'cv06' 1, 'cv08' 1;
    margin: 0;
  }

  /* ── Steps ── */
  .process-content-wrapper {
    max-width: 1200px;
    width: 100%;
  }

  .steps-grid {
    display: flex;
    gap: var(--space-fixed-md-1, 24px);
    justify-content: center;
    width: 100%;
  }

  .step-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-5, 16px);
    align-items: center;
    flex: 1 0 0;
    max-width: 400px;
    min-width: 148px;
    transition: transform 0.2s ease;
  }

  .step-card:hover {
    transform: translateY(-4px);
  }

  .step-image {
    width: 148px;
    height: 148px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
  }

  .step-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-3, 8px);
    align-items: center;
    text-align: center;
    width: 100%;
  }

  .step-title {
    font-family: var(--font-family-heading, "Inter");
    font-size: var(--font-size-h6, 20px);
    font-weight: var(--font-weight-high, 700);
    line-height: var(--font-line-height-h6, 26px);
    letter-spacing: var(--font-letter-spacing-h6, -0.35px);
    color: var(--colour-text-intense-neutral, #282828);
    margin: 0;
  }

  .step-description {
    font-family: var(--font-family-body, "Inter");
    font-size: var(--font-size-subtitle-1, 16px);
    font-weight: var(--font-weight-regular, 400);
    line-height: var(--font-line-height-subtitle-1, 24px);
    letter-spacing: var(--font-letter-spacing-subtitle-1-regular, 0px);
    color: var(--colour-text-intense-neutral, #282828);
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .our-simple-process {
      padding-left: var(--space-fixed-md-2, 32px);
      padding-right: var(--space-fixed-md-2, 32px);
    }

    .steps-grid {
      flex-wrap: wrap;
    }
  }

  @media (max-width: 768px) {
    .our-simple-process {
      padding-left: var(--space-fixed-md-1, 24px);
      padding-right: var(--space-fixed-md-1, 24px);
    }
  }

  @media (max-width: 640px) {
    .our-simple-process {
      gap:0;
      padding-top: var(--space-fixed-sm-3, 8px);
      padding-bottom: var(--space-fixed-md-1, 24px);
      padding-left: var(--space-fixed-sm-5, 16px);
      padding-right: var(--space-fixed-sm-5, 16px);
      overflow: clip;
    }

    .process-header {
      align-items: flex-start;
      text-align: left;
    }

    .process-title {
      font-size: var(--font-size-h5, 25px);
      line-height: var(--font-line-height-h5, 30px);
      letter-spacing: var(--font-letter-spacing-h5, -0.5px);
    }

    .steps-grid {
      flex-direction: column;
      gap:0;
      align-items: flex-start;
    }

    .step-card {
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      max-width: 400px;
      min-width: 128px;
      padding-top: var(--space-fixed-sm-3, 8px);
      padding-bottom: var(--space-fixed-sm-3, 8px);
    }

    .step-card:hover {
      transform: none;
    }

    .step-image {
      width: 88px;
      height: 88px;
      flex-shrink: 0;
    }

    .step-content {
      align-items: flex-start;
      text-align: left;
      gap: var(--space-fixed-sm-2, 4px);
    }
  }
</style>
