---
// TextField component for phone input
---

<div class="text-field" data-node-id="21832:14689">
  <div class="input-area phone-input" data-node-id="21832:15414">
    <div class="input-content" data-node-id="21832:15415">
      <div class="phone-code-section" data-node-id="21832:15416">
        <div class="flag-icon" data-node-id="21832:15417">
          <img 
            src="http://localhost:3845/assets/c0d40a5f552aa4a1e6794b9071cd777d61e8d4fc.png" 
            alt="India flag"
            class="flag-image"
            data-node-id="21832:15418"
          />
        </div>
        <div class="code-dropdown" data-node-id="21832:15419">
          <span>+91</span>
          <button class="chevron-btn" data-node-id="21832:15421">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M7 10L12 15L17 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="divider" data-node-id="21832:15422"></div>
      <input 
        type="tel" 
        placeholder="Mobile number" 
        class="phone-input-field"
        data-node-id="21832:15423"
      />
    </div>
  </div>
</div>

<style>
  .text-field {
    display: flex;
    flex-direction: column;
    gap: var(--fixed-100);
    align-items: flex-start;
    padding: var(--fixed-100) 0;
    width: 100%;
  }

  .input-area {
    height: 48px;
    width: 100%;
    border: 1px solid var(--colour-border-subtle-neutral);
    border-radius: var(--size-border-radius-md);
    position: relative;
  }

  .input-content {
    position: absolute;
    top: 50%;
    left: 15px;
    right: 11px;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: var(--space-fixed-sm-4);
    height: 24px;
  }

  .phone-code-section {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .flag-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .flag-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 2px;
  }

  .code-dropdown {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .code-dropdown span {
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-subtitle-1);
    line-height: var(--font-line-height-subtitle-1);
    color: var(--colour-text-intense-neutral);
    white-space: nowrap;
  }

  .chevron-btn {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--colour-text-intense-neutral);
  }

  .divider {
    width: 0;
    height: 24px;
    border-left: 1px solid var(--colour-border-subtle-neutral);
    flex-shrink: 0;
  }

  .phone-input-field {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-subtitle-1);
    line-height: var(--font-line-height-subtitle-1);
    color: var(--colour-text-moderate-neutral);
    background: transparent;
  }

  .phone-input-field::placeholder {
    color: var(--colour-text-moderate-neutral);
  }
</style>
