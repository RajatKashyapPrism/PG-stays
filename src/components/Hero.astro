---
import LibraryTextField from './LibraryTextField';
import LibraryPhoneField from './LibraryPhoneField';
import LibraryButton from './LibraryButton';
import { Image } from 'astro:assets';
---

<header class="hero" data-node-id="21671:9815">
  <div class="hero-wrapper">
    <section class="hero-content" data-node-id="21671:9819">
    <div class="titles" data-node-id="21671:11696">
      <p class="main-title" data-node-id="21671:11697">
        Premium PG Living.<br />
        Zero Hassle.
      </p>
      <p class="subtitle" data-node-id="21671:11698">
        Well-designed co-living spaces for professionals. A premium experience focused on comfort, convenience, and value.
      </p>
    </div>

    <div class="contact-form" data-node-id="21671:14112">
      <LibraryTextField client:load label="Full name" />
      <LibraryTextField client:load label="City" />
      <LibraryPhoneField client:load label="Mobile number" placeholder="Mobile number" />
    </div>

    <LibraryButton
      client:load
      label="Get free callback"
      href="https://contact.oyoassets.com/"
      variant="primary"
      size="lg"
      fullWidth
    />
  </section>

  <div class="hero-image-wrapper">
    <div class="hero-image" data-node-id="21671:9818">
      <Image
        src="http://localhost:3845/assets/e77a3a6b6df5fe225b6584faf93f5682a5d90112.png" 
        alt="sunday proptech" 
        class="image"
        width={600}
        height={600}
        loading="eager"
      />
    </div>
  </div>
  </div>
</header>

<style>
  .hero {
    background: var(--colour-background-intense-brand-invert-primary);
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    align-items: center;
    overflow: clip;
    padding-bottom: var(--space-scale-md-3, 40px);
    padding-top: var(--space-fixed-md-1, 24px);
    padding-left: var(--space-fixed-md-4, 48px);
    padding-right: var(--space-fixed-md-4, 48px);
    border-radius: var(--size-border-radius-xl, 16px);
    width: 100%;
    position: relative;
  }

  .hero-wrapper {
    max-width: 1200px;
    width: 100%;
    display: flex;
    gap: 48px;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .hero-content {
    background: var(--colour-background-subtle-neutral-1);
    display: flex;
    flex: 1 0 0;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    align-items: center;
    justify-content: center;
    max-width: 400px;
    min-height: 1px;
    min-width: 1px;
    overflow: hidden;
    padding-top: var(--space-fixed-md-4, 48px);
    position: relative;
    z-index: 2;
  }

  .titles {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-5);
    align-items: flex-start;
    position: relative;
    width: 100%;
  }

  .main-title {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    font-weight: 700;
    font-size: 32px;
    line-height: 40px;
    letter-spacing: -0.6px;
    color: var(--colour-text-intense-neutral);
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .subtitle {
    font-family: 'Host Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0.3px;
    color: var(--colour-text-moderate-neutral);
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-5);
    align-items: stretch;
    position: relative;
    width: 100%;
  }

  /* astro-island is inline by default — make it block so children can be full width */
  .contact-form astro-island,
  .hero-content > astro-island {
    display: block;
    width: 100%;
  }

  .hero-image-wrapper {
    display: flex;
    flex: 1 0 0;
    flex-direction: row;
    align-items: center;
    align-self: stretch;
  }

  .hero-image {
    flex: 1 0 0;
    height: 100%;
    min-height: 1px;
    min-width: 1px;
    position: relative;
    border-radius: var(--size-border-radius-xl);
    z-index: 1;
  }

  .image {
    position: absolute;
    inset: 0;
    max-width: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    border-radius: var(--size-border-radius-xl);
  }

  @media (max-width: 1024px) {
    .hero {
      padding-left: var(--space-fixed-md-2, 32px);
      padding-right: var(--space-fixed-md-2, 32px);
    }

    .hero-wrapper {
      flex-direction: column;
      gap: 0;
    }

    .hero-content {
      max-width: 100%;
      flex: 1 0 auto;
      min-height: auto;
      padding-top: var(--space-fixed-md-4, 48px);
    }

    .hero-image-wrapper {
      width: 100%;
      min-height: 400px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-left: var(--space-fixed-md-1, 24px);
      padding-right: var(--space-fixed-md-1, 24px);
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-left: var(--space-fixed-sm-5, 16px);
      padding-right: var(--space-fixed-sm-5, 16px);
      gap: 0;
    }

    .hero-wrapper {
      gap: 0;
    }

    .hero-content {
      max-width: 100%;
      padding-top: var(--space-fixed-md-1, 24px);
      padding-left: 0;
      padding-right: 0;
    }

    .main-title {
      font-size: 24px;
      line-height: 32px;
      letter-spacing: -0.48px;
    }

    .subtitle {
      font-size: 14px;
      line-height: 20px;
      letter-spacing: 0px;
    }
  }
</style>
