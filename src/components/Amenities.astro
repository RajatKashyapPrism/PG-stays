---
import AmenityCard from './AmenityCard.astro';

type AmenityData = {
  image: string;
  label: string;
};

const amenities: AmenityData[] = [
  { image: "/images/amenity-wifi.png", label: "Hi-Speed WiFi" },
  { image: "/images/amenity-ac.png", label: "AC" },
  { image: "/images/amenity-backup.png", label: "24/7 Backup" },
  { image: "/images/amenity-housekeeping.png", label: "Housekeeping" },
  { image: "/images/amenity-tv.png", label: "Smart TV" },
];
---

<section class="amenities" id="amenities">
  <!-- Header -->
  <div class="amenities-header-wrapper">
    <div class="amenities-header">
      <p class="amenities-heading">Everything You Need</p>
      <p class="amenities-subtitle">Modern amenities for a modern lifestyle. No compromises.</p>
    </div>
  </div>

  <!-- Cards -->
  <div class="amenities-content-wrapper">
    <div class="amenities-row">
      {amenities.map((amenity) => (
        <AmenityCard image={amenity.image} label={amenity.label} />
      ))}
    </div>
  </div>
</section>

<style>
  .amenities {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    align-items: center;
    padding-bottom: var(--space-scale-md-3, 40px);
    padding-top: var(--space-fixed-md-1, 24px);
    padding-left: var(--space-fixed-md-4, 48px);
    padding-right: var(--space-fixed-md-4, 48px);
    border-radius: var(--size-border-radius-xl, 16px);
    width: 100%;
  }

  /* ── Header ── */
  .amenities-header-wrapper {
    max-width: 1200px;
    width: 100%;
  }

  .amenities-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-3, 8px);
    align-items: center;
    justify-content: center;
    padding-bottom: var(--space-fixed-sm-3, 8px);
    padding-top: var(--space-fixed-sm-5, 16px);
    text-align: center;
    width: 100%;
  }

  .amenities-heading {
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-heading, 700);
    font-size: var(--font-size-h4, 32px);
    line-height: var(--font-line-height-h4, 40px);
    letter-spacing: var(--font-letter-spacing-h4, -0.6px);
    color: var(--colour-text-intense-neutral, #282828);
    font-feature-settings: 'ss01' 1, 'cv06' 1, 'cv05' 1, 'cv08' 1, 'cv10' 1;
    margin: 0;
  }

  .amenities-subtitle {
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular, 400);
    font-size: var(--font-size-subtitle-1, 16px);
    line-height: var(--font-line-height-subtitle-1, 24px);
    letter-spacing: var(--font-letter-spacing-subtitle-1-regular, 0px);
    color: var(--colour-text-moderate-neutral, #6c6c6c);
    font-feature-settings: 'ss01' 1, 'cv01' 1, 'cv02' 1, 'cv03' 1, 'cv04' 1, 'cv05' 1, 'cv06' 1, 'cv08' 1;
    margin: 0;
  }

  /* ── Cards ── */
  .amenities-content-wrapper {
    max-width: 1200px;
    width: 100%;
  }

  .amenities-row {
    display: flex;
    gap: var(--space-fixed-md-1, 24px);
    align-items: start;
    width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .amenities {
      padding-left: var(--space-fixed-md-2, 32px);
      padding-right: var(--space-fixed-md-2, 32px);
    }

    .amenities-row {
      flex-wrap: wrap;
      gap: var(--space-fixed-sm-5, 16px);
    }

  }

  @media (max-width: 768px) {
    .amenities {
      padding-left: var(--space-fixed-md-1, 24px);
      padding-right: var(--space-fixed-md-1, 24px);
    }
  }

  @media (max-width: 640px) {
    /* Section goes edge-to-edge — scroll track owns the gutter */
    .amenities {
      padding-top: var(--space-fixed-sm-3, 8px);
      padding-bottom: var(--space-fixed-sm-5, 16px);
      padding-left: 0;
      padding-right: 0;
      overflow: visible; /* never clip the scroll track's overflow-y */
      align-items: stretch;
    }

    /* Header gets its own gutter since section padding is removed */
    .amenities-header-wrapper {
      padding-left: var(--space-fixed-sm-5, 16px);
      padding-right: var(--space-fixed-sm-5, 16px);
    }

    .amenities-header {
      align-items: flex-start;
      text-align: left;
    }

    .amenities-heading {
      font-size: var(--font-size-h5, 25px);
      line-height: var(--font-line-height-h5, 30px);
      letter-spacing: var(--font-letter-spacing-h5, -0.5px);
      text-align: left;
    }

    .amenities-subtitle {
      text-align: left;
    }

    /* Content wrapper stretches to full width, not constrained */
    .amenities-content-wrapper {
      max-width: 100%;
      overflow: visible;
    }

    /* Scroll track — owns the left/right gutter (Apple pattern) */
    .amenities-row {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: visible;
      scroll-snap-type: x mandatory;
      scroll-padding-left: var(--space-fixed-sm-5, 16px); /* snap offset matches padding */
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-left: var(--space-fixed-sm-5, 16px);  /* the visible left gutter */
      padding-right: var(--space-fixed-sm-5, 16px);
      padding-bottom: var(--fixed-50, 4px);
    }

    .amenities-row::-webkit-scrollbar {
      display: none;
    }

    :global(.amenity-card) {
      scroll-snap-align: start;
      flex: 0 0 var(--scale-1400, 128px);
      min-width: 0;
    }
  }
</style>
