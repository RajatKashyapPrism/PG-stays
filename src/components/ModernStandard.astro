---
import { Image } from 'astro:assets';

type CardData = {
  image: string;
  title: string;
  description: string;
};

const cards: CardData[] = [
  {
    image: "/images/modern-standard-1.png",
    title: "Transparent core",
    description: "No hidden fees. No brokerage. Just direct management.",
  },
  {
    image: "/images/modern-standard-2.png",
    title: "Managed precision",
    description: "Fully managed with weekly deep cleaning and preventive care.",
  },
  {
    image: "/images/modern-standard-3.png",
    title: "Design first",
    description: "Minimal design with ergonomic, functional furniture for mental clarity.",
  },
  {
    image: "/images/modern-standard-4.png",
    title: "Urban access",
    description: "Near major transit hubs, so you commute less and live more.",
  },
];
---

<section class="modern-standard">
  <!-- Header -->
  <div class="modern-standard-header">
    <div class="header-content">
      <p class="main-heading">
        The Modern Standard
      </p>
      <p class="subtitle">
        Everything you expect, redefined with precision and care.
      </p>
    </div>
  </div>

  <!-- Grid -->
  <div class="grid-wrapper">
    <div class="grid-content">
      {cards.map((card) => (
        <div class="card">
          <div class="card-image">
            <div class="image-container">
              <Image src={card.image} alt={card.title} width={400} height={282} loading="lazy" />
            </div>
          </div>
          <div class="card-strings">
            <div class="card-title-wrapper">
              <p class="card-title">{card.title}</p>
            </div>
            <p class="card-description">{card.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .modern-standard {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    align-items: center;
    overflow: clip;
    padding-bottom: var(--space-scale-md-3, 40px);
    padding-top: var(--space-fixed-md-1, 24px);
    padding-left: var(--space-fixed-md-4, 48px);
    padding-right: var(--space-fixed-md-4, 48px);
    border-radius: var(--size-border-radius-xl, 16px);
    width: 100%;
  }

  /* ── Header ── */
  .modern-standard-header {
    max-width: 1200px;
    width: 100%;
    position: relative;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-3, 8px);
    align-items: center;
    justify-content: center;
    padding-bottom: var(--space-fixed-sm-3, 8px);
    padding-top: var(--space-fixed-sm-5, 16px);
    text-align: center;
    width: 100%;
  }

  .main-heading {
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-heading, 700);
    font-size: var(--font-size-h4, 32px);
    line-height: var(--font-line-height-h4, 40px);
    letter-spacing: var(--font-letter-spacing-h4, -0.6px);
    color: var(--colour-text-intense-neutral, #282828);
    font-feature-settings: 'ss01' 1, 'cv06' 1, 'cv05' 1, 'cv08' 1, 'cv10' 1;
    width: 100%;
    margin: 0;
  }

  .subtitle {
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular, 400);
    font-size: var(--font-size-subtitle-1, 16px);
    line-height: var(--font-line-height-subtitle-1, 24px);
    letter-spacing: var(--font-letter-spacing-subtitle-1-regular, 0px);
    color: var(--colour-text-moderate-neutral, #6c6c6c);
    font-feature-settings: 'ss01' 1, 'cv01' 1, 'cv02' 1, 'cv03' 1, 'cv04' 1, 'cv05' 1, 'cv06' 1, 'cv08' 1;
    max-width: 1200px;
    width: 100%;
    margin: 0;
  }

  /* ── Grid ── */
  .grid-wrapper {
    max-width: 1200px;
    width: 100%;
    position: relative;
  }

  .grid-content {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-fixed-md-1, 24px);
    align-items: start;
    justify-content: center;
    width: 100%;
  }

  /* ── Card ── */
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    align-items: start;
    flex: 1 0 0;
    max-width: 400px;
    min-width: 148px;
  }

  /* ── Card Image ── */
  .card-image {
    height: 282px;
    width: 100%;
    border-radius: var(--size-border-radius-xl, 16px);
    position: relative;
  }

  .image-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: var(--size-border-radius-xl, 16px);
    pointer-events: none;
  }

  .image-container img {
    position: absolute;
    height: 100%;
    width: 100%;
    object-fit: cover;
    top: 0;
    left: 0;
  }

  /* ── Card Text ── */
  .card-strings {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-3, 8px);
    align-items: start;
    color: var(--colour-text-intense-neutral, #282828);
    text-align: left;
    width: 100%;
  }

  .card-title-wrapper {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 24px;
    width: 100%;
  }

  .card-title {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    font-weight: var(--font-weight-heading, 700);
    font-size: var(--font-size-h6, 20px);
    line-height: var(--font-line-height-h6, 26px);
    letter-spacing: var(--font-letter-spacing-h6, -0.35px);
    margin: 0;
    font-feature-settings: 'cv01', 'cv02', 'cv03', 'cv04', 'cv05', 'cv06', 'cv08', 'cv10', 'ss01', 'ss03', 'cv09';
  }

  .card-description {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-weight: var(--font-weight-regular, 400);
    font-size: var(--font-size-subtitle-1, 16px);
    line-height: var(--font-line-height-subtitle-1, 24px);
    letter-spacing: var(--font-letter-spacing-subtitle-1-regular, 0px);
    color: var(--colour-text-intense-neutral, #282828);
    width: 100%;
    margin: 0;
    font-feature-settings: 'ss01', 'cv01', 'cv02', 'cv03', 'cv04', 'cv05', 'cv06', 'cv08';
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .modern-standard {
      padding-left: var(--space-fixed-md-2, 32px);
      padding-right: var(--space-fixed-md-2, 32px);
    }
  }

  @media (max-width: 768px) {
    .modern-standard {
      padding-left: var(--space-fixed-md-1, 24px);
      padding-right: var(--space-fixed-md-1, 24px);
    }

    .card {
      max-width: 100%;
      min-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .modern-standard {
      gap: var(--space-fixed-sm-3, 8px);
      padding-top: var(--space-fixed-sm-3, 8px);
      padding-bottom: var(--space-fixed-md-1, 24px);
      padding-left: var(--space-fixed-sm-5, 16px);
      padding-right: var(--space-fixed-sm-5, 16px);
    }

    .header-content {
      align-items: flex-start;
      text-align: left;
    }

    .main-heading {
      font-size: var(--font-size-h5, 25px);
      line-height: var(--font-line-height-h5, 30px);
      letter-spacing: var(--font-letter-spacing-h5, -0.5px);
    }

    .grid-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-fixed-sm-5, 16px);
    }

    .card {
      max-width: 100%;
      min-width: 0;
      gap: var(--space-fixed-sm-5, 16px);
    }

    .card-image {
      height: auto;
      aspect-ratio: 1 / 1;
    }

    .card-strings {
      gap: var(--space-fixed-sm-2, 4px);
    }

    .card-title {
      font-size: var(--font-size-subtitle-1, 16px);
      line-height: var(--font-line-height-subtitle-1, 24px);
      letter-spacing: var(--font-letter-spacing-subtitle-1-high, -0.3px);
    }

    .card-description {
      font-size: var(--font-size-subtitle-2, 14px);
      line-height: var(--font-line-height-subtitle-2, 22px);
      letter-spacing: var(--font-letter-spacing-subtitle-2-regular, 0px);
    }
  }
</style>
