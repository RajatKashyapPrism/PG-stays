---
import LibraryPhoneField from '../components/LibraryPhoneField';
import LibraryButton from '../components/LibraryButton';
---

<header class="hero">
  <div class="hero-inner">
    <div class="hero-visual" aria-hidden="true">
      <img src="/images/img_hero.webp" alt="" class="hero-visual-image" />
    </div>
    <section class="hero-card">
      <div class="titles">
        <p class="main-title">
          Premium PG Living.<br />
          Zero Hassle.
        </p>

        <ul class="hero-usps" aria-label="Key benefits">
          <li class="hero-usp">
            <span class="hero-usp-icon" aria-hidden="true">
              <svg viewBox="0 0 10 8" focusable="false">
                <path d="M1 4.1 3.6 6.7 9 1.3" />
              </svg>
            </span>
            <span>Zero brokerage</span>
          </li>
          <li class="hero-usp">
            <span class="hero-usp-icon" aria-hidden="true">
              <svg viewBox="0 0 10 8" focusable="false">
                <path d="M1 4.1 3.6 6.7 9 1.3" />
              </svg>
            </span>
            <span>Move-in within 24 hours</span>
          </li>
          <li class="hero-usp">
            <span class="hero-usp-icon" aria-hidden="true">
              <svg viewBox="0 0 10 8" focusable="false">
                <path d="M1 4.1 3.6 6.7 9 1.3" />
              </svg>
            </span>
            <span>5,000+ already living with us</span>
          </li>
        </ul>
      </div>

      <form id="hero-contact-form" class="contact-form" action="https://contact.oyoassets.com/" method="get">
        <input type="hidden" name="source" value="hero" />
        <LibraryPhoneField
          client:load
          label="Mobile number"
          name="phone"
          placeholder="Enter mobile number"
          isRequired
        />

        <LibraryButton
          client:load
          label="Get PG options"
          variant="primary"
          size="lg"
          fullWidth
          type="submit"
        />

        <p class="hero-footnote">
          <span class="hero-footnote-icon" aria-hidden="true">
            <svg viewBox="0 0 16 16" focusable="false">
              <circle cx="8" cy="8" r="5.75" />
              <path d="M8 5.1v3.2l2 1.2" />
              <path d="M8 1.5v1.4" />
              <path d="M5.2 1.8h5.6" />
            </svg>
          </span>
          <span>No spam. We’ll call you within 5 minutes.</span>
        </p>
      </form>
    </section>
  </div>
</header>

<style>
  .hero {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: var(--space-fixed-md-4, 48px) var(--space-fixed-sm-5, 16px);
    background-image: url('/images/img_hero.webp');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    min-height: 560px;
  }

  .hero-inner {
    width: 100%;
    max-width: 1200px;
    display: flex;
    align-items: center;
  }

  .hero-card {
    width: min(100%, 464px);
    background: var(--colour-background-subtle-neutral-1, #fff);
    border-radius: var(--size-border-radius-xxl, 24px);
    display: flex;
    flex-direction: column;
    gap: var(--space-scale-md-1, 24px);
    padding: var(--space-fixed-md-3, 40px);
    box-shadow:
      0 0 4px rgba(0, 0, 0, 0.08),
      0 5px 10px rgba(0, 0, 0, 0.06),
      0 18px 18px rgba(0, 0, 0, 0.08),
      0 41px 24px rgba(0, 0, 0, 0.05),
      0 72px 29px rgba(0, 0, 0, 0.01),
      0 113px 32px rgba(0, 0, 0, 0);
  }

  .titles {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    width: 100%;
  }

  .main-title {
    margin: 0;
    color: var(--colour-text-intense-neutral, #282828);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 40px;
    font-weight: 700;
    line-height: 48px;
    letter-spacing: -1px;
  }

  .hero-usps {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-fixed-sm-3, 8px);
    margin: 0;
    padding: 0;
    list-style: none;
    color: var(--colour-text-intense-neutral, #282828);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
  }

  .hero-usp {
    display: inline-flex;
    align-items: center;
    gap: var(--space-fixed-sm-2, 4px);
  }

  .hero-usp-icon {
    display: inline-flex;
    width: 16px;
    height: 16px;
    align-items: center;
    justify-content: center;
    color: var(--colour-text-intense-neutral, #282828);
  }

  .hero-usp-icon svg {
    width: 10px;
    height: 8px;
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-md-1, 24px);
    width: 100%;
  }

  .contact-form > astro-island {
    display: block;
    width: 100%;
  }

  .hero-footnote {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-fixed-sm-3, 8px);
    margin: 8px 0 0;
    width: 100%;
    color: var(--colour-text-intense-neutral, #282828);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 22px;
    text-align: center;
  }

  .hero-footnote-icon {
    display: inline-flex;
    width: 16px;
    height: 16px;
    align-items: center;
    justify-content: center;
    color: var(--colour-text-intense-neutral, #282828);
    flex-shrink: 0;
  }

  .hero-footnote-icon svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 1.4;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hero-visual {
    display: none;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 0;
      padding-top: var(--space-fixed-md-3, 40px);
      padding-bottom: var(--space-fixed-md-3, 40px);
      background: none;
    }

    .hero-inner {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-fixed-sm-3, 8px);
    }

    .hero-visual {
      display: block;
      width: 100%;
      min-height: 400px;
      border-radius: var(--size-border-radius-xl, 16px);
      overflow: hidden;
    }

    .hero-visual-image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-card {
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
      background: var(--colour-background-subtle-neutral-1, #fff);
      box-shadow: none;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 0;
      padding-top: var(--space-fixed-sm-3, 8px);
      padding-bottom: var(--space-fixed-md-1, 24px);
      background: none;
    }

    .hero-card {
      width: 100%;
      max-width: 400px;
      padding: var(--space-fixed-sm-5, 16px) 0 0;
      border-radius: 0;
      box-shadow: none;
    }

    .hero-visual {
      min-height: 0;
      aspect-ratio: 328 / 218;
    }

    .main-title {
      font-size: 32px;
      line-height: 40px;
      letter-spacing: -0.6px;
    }

    .hero-footnote {
      justify-content: flex-start;
      text-align: left;
    }
  }
</style>
