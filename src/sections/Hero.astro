---
import LibraryTextField from '../components/LibraryTextField';
import LibraryPhoneField from '../components/LibraryPhoneField';
import LibraryButton from '../components/LibraryButton';
---

<header class="hero">
  <div class="hero-inner">
    <div class="hero-visual" aria-hidden="true">
      <img src="/images/img_hero.webp" alt="" class="hero-visual-image" />
    </div>
    <section class="hero-card">
      <div class="titles">
        <p class="main-title">
          Premium PG Living.<br />
          Zero Hassle.
        </p>
        <p class="subtitle">
          Well-designed co-living spaces for professionals. A premium experience focused on comfort,
          convenience and value.
        </p>
      </div>

      <form id="hero-contact-form" class="contact-form" action="https://contact.oyoassets.com/" method="get">
        <input type="hidden" name="source" value="hero" />
        <LibraryTextField client:load label="Full name" name="fullName" autoComplete="name" isRequired errorMessage="Enter your name" />
        <LibraryTextField client:load label="City" name="city" autoComplete="address-level2" isRequired errorMessage="Enter your preferred city" />
        <LibraryPhoneField client:load label="Mobile number" name="phone" placeholder="Mobile number" isRequired />
        <LibraryButton
          client:load
          label="Get free callback"
          variant="primary"
          size="lg"
          fullWidth
          type="submit"
        />
      </form>
    </section>
  </div>
</header>

<style>
  .hero {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: var(--space-fixed-md-4, 48px) var(--space-fixed-sm-5, 16px);
    background-image: url('/images/img_hero.webp');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    min-height: 560px;
  }

  .hero-inner {
    width: 100%;
    max-width: 1200px;
    display: flex;
    align-items: center;
  }

  .hero-card {
    width: min(100%, 480px);
    background: var(--colour-background-subtle-neutral-1, #fff);
    border-radius: var(--size-border-radius-xxl, 24px);
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-5, 16px);
    padding: var(--space-fixed-md-3, 40px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
  }

  .titles {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-5, 16px);
    width: 100%;
  }

  .main-title {
    margin: 0;
    color: var(--colour-text-intense-neutral, #282828);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 40px;
    letter-spacing: -0.6px;
  }

  .subtitle {
    margin: 0;
    color: var(--colour-text-moderate-neutral, #6c6c6c);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0;
  }

  .contact-form {
    display: flex;
    gap: var(--space-fixed-sm-5, 16px);
    flex-direction: column;
    width: 100%;
  }

  .contact-form > astro-island {
    display: block;
    width: 100%;
  }

  .hero-visual {
    display: none;
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 0;
      padding-top: var(--space-fixed-md-3, 40px);
      padding-bottom: var(--space-fixed-md-3, 40px);
      background: none;
    }

    .hero-inner {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-fixed-sm-3, 8px);
    }

    .hero-visual {
      display: block;
      width: 100%;
      min-height: 400px;
      border-radius: var(--size-border-radius-xl, 16px);
      overflow: hidden;
    }

    .hero-visual-image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-card {
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
      background: var(--colour-background-subtle-neutral-1, #fff);
      box-shadow: none;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 0;
      padding-top: var(--space-fixed-sm-3, 8px);
      padding-bottom: var(--space-fixed-md-1, 24px);
      background: none;
    }

    .hero-card {
      width: 100%;
      max-width: 400px;
      padding: var(--space-fixed-sm-5, 16px) 0 0;
      border-radius: 0;
      box-shadow: none;
    }

    .hero-visual {
      min-height: 0;
      aspect-ratio: 328 / 218;
    }

    .main-title {
      font-size: 32px;
      line-height: 40px;
    }
  }
</style>
