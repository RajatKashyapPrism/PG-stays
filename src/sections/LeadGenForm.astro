---
import LibraryTextField from '../components/LibraryTextField';
import LibraryPhoneField from '../components/LibraryPhoneField';
import LibraryButton from '../components/LibraryButton';
import { Image } from 'astro:assets';
---

<section id="lead-gen-form" class="lead-gen">
  <!-- Desktop full-bleed image — absolutely positioned, hidden on mobile -->
  <Image
    src="/images/img_hero.webp"
    alt=""
    class="lead-gen-bg-image"
    width={1200}
    height={480}
    aria-hidden="true"
  />

  <div class="lead-gen-inner">
    <div class="lead-gen-card">
      <!-- Shown on mobile only — hidden on desktop where abs image takes over -->
      <div class="lead-gen-image-wrapper">
        <Image
          src="/images/img_hero.webp"
          alt="Book a free visit"
          class="lead-gen-image"
          width={656}
          height={436}
        />
      </div>

      <div class="lead-gen-form">
        <h2 class="lead-gen-heading">Book a free visit today</h2>

        <form class="lead-gen-fields" action="https://contact.oyoassets.com/" method="get">
          <input type="hidden" name="source" value="footer" />
          <LibraryTextField client:load label="Full name" name="fullName" autoComplete="name" isRequired />
          <LibraryTextField client:load label="City" name="city" autoComplete="address-level2" isRequired />
          <LibraryPhoneField client:load label="Mobile number" name="phone" placeholder="Mobile number" isRequired />
          <LibraryButton
            client:load
            label="Submit"
            variant="primary"
            size="lg"
            fullWidth
            type="submit"
          />
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Mobile-first base ── */
  .lead-gen {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: var(--space-fixed-sm-5, 16px);
    margin-bottom: var(--space-fixed-sm-5, 16px);
    padding: var(--space-fixed-sm-3, 8px) var(--space-fixed-sm-5, 16px) var(--space-fixed-sm-5, 16px);
    scroll-margin-top: 96px;
    width: 100%;
    box-sizing: border-box;
  }

  .lead-gen-inner {
    max-width: 1200px;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .lead-gen-card {
    background: var(--colour-background-subtle-neutral-1, #ffffff);
    border-radius: var(--size-border-radius-xl, 16px);
    box-shadow: 0px 4px 24px 0px rgba(0, 0, 0, 0.12);
    overflow: hidden;
    width: 100%;
  }

  .lead-gen-image-wrapper {
    aspect-ratio: 328 / 218;
    width: 100%;
    overflow: hidden;
  }

  .lead-gen-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lead-gen-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-5, 16px);
    padding: var(--space-fixed-sm-5, 16px);
  }

  .lead-gen-heading {
    font-family: var(--font-family-heading, 'Inter', sans-serif);
    font-weight: 700;
    font-size: var(--font-size-h5, 25px);
    line-height: var(--font-line-height-h5, 30px);
    letter-spacing: var(--font-letter-spacing-h5, -0.5px);
    color: var(--colour-text-intense-neutral, #282828);
    margin: 0;
  }

  .lead-gen-fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-fixed-sm-5, 16px);
  }

  /* Make astro-island block so inputs stretch full width */
  .lead-gen-fields astro-island,
  .lead-gen-form > astro-island {
    display: block;
    width: 100%;
  }

  /* Desktop full-bleed image — hidden on mobile */
  .lead-gen-bg-image {
    display: none;
  }

  /* ── Desktop layout ── */
  @media (min-width: 1024px) {
    .lead-gen {
      position: relative;
      padding: var(--space-scale-md-3, 40px);
      margin-top: var(--space-fixed-md-5, 64px);
      margin-bottom: var(--space-fixed-md-5, 64px);
      min-height: 480px;
    }

    /* Absolute full-bleed background image */
    .lead-gen-bg-image {
      display: block;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      pointer-events: none;
    }

    .lead-gen-inner {
      justify-content: flex-end;
      align-items: center;
      position: relative; /* stack above the abs image */
      z-index: 1;
    }

    .lead-gen-card {
      max-width: 444px;
      box-shadow:
        0px 11px 15px rgba(0, 0, 0, 0.06),
        0px 9px 46px rgba(0, 0, 0, 0.04),
        0px 24px 38px rgba(0, 0, 0, 0.08);
    }

    /* Hide the card image — full-bleed img takes over */
    .lead-gen-image-wrapper {
      display: none;
    }

    .lead-gen-form {
      padding: var(--space-fixed-md-1, 24px);
    }
  }
</style>
